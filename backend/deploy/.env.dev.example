DB_NAME=code_trainer
DB_USER=code_trainer
DB_PASSWORD=change_me
# Минимум 32 символа; не placeholder из shared/config.py
AUTH__SECRET_KEY=dev_local_only_not_for_production_secret_32

# host-side ports
# На Windows Hyper-V часто блокирует 7961–8060 (в т.ч. 8001). Используйте 9000 или другой свободный порт.
API_PORT=9000
POSTGRES_PORT=5433
REDIS_PORT=6379

# Если Docker Hub недоступен (TLS timeout), укажите зеркало или уже скачанный тег:
# PYTHON_BASE_IMAGE=python:3.12-slim
# Mailpit (веб-интерфейс писем). На Windows не используйте 8025 — диапазон 7961–8060 часто занят Hyper-V.
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=9025

# queue names
SUBMISSION_QUEUE=submissions:queue
SUBMISSION_RESULT_PREFIX=submissions:result:
LINT_QUEUE=lint:queue
LINT_RESULT_PREFIX=lint:result:

# Лимиты execution (compile/lint/submit): запросов на пользователя в минуту и одновременно
# lint_only не учитывается в поминутном лимите (автолинт при наборе кода)
EXECUTION_USER_MAX_PER_MINUTE=120
EXECUTION_USER_MAX_CONCURRENT=8

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Автобэкап БД (сервис db_backup в docker-compose, раз в сутки)
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=1
BACKUP_RETENTION_MAX_COUNT=7

# Демо без регистрации (защита ВКР): /guest/check, страница /demo
GUEST_MODE__ENABLED=true

# Локальный admin для seed_admin.py (docker exec ... python scripts/seed_admin.py)
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=dev_admin_pass_12
SEED_ADMIN_NAME=Admin

# --- OAuth (соц. вход: VK, Google, Яндекс) ---
OAUTH__FRONTEND_URL=http://localhost:5173
OAUTH__REDIRECT_BASE=http://127.0.0.1:9000
# OAUTH__VK_CLIENT_ID=
# OAUTH__GOOGLE_CLIENT_ID=
# OAUTH__GOOGLE_CLIENT_SECRET=
# OAUTH__YANDEX_CLIENT_ID=
# OAUTH__YANDEX_CLIENT_SECRET=
