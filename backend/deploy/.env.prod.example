# Production environment — copy to backend/deploy/.env.prod and fill in real values.
# Deploy: ./deploy/scripts/init-prod.sh  (Linux/macOS)
#         .\deploy\scripts\init-prod.ps1  (Windows)

# --- Доступ (домен + HTTPS) ---
DOMAIN=code-trainer.ru
ACME_EMAIL=admin@example.com
ENABLE_SSL=1
VITE_API_BASE_URL=/api
CORS_ORIGINS=https://code-trainer.ru

# По IP без SSL (legacy):
# DOMAIN=92.63.102.50
# ENABLE_SSL=0
# CORS_ORIGINS=http://92.63.102.50

# --- Database ---
DB_NAME=code_trainer
DB_USER=code_trainer
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# --- Auth ---
AUTH__SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32

# --- SMTP (registration email codes) ---
SMTP__HOST=smtp.example.com
SMTP__PORT=587
SMTP__USER=noreply@example.com
SMTP__PASSWORD=REPLACE_SMTP_PASSWORD
SMTP__USE_TLS=true
SMTP__FROM_EMAIL=noreply@example.com

# --- OAuth (VK, Google, Yandex) ---
# Prod callbacks: {OAUTH__REDIRECT_BASE}/auth/oauth/{vk|google|yandex}/callback
OAUTH__FRONTEND_URL=https://code-trainer.ru
OAUTH__REDIRECT_BASE=https://code-trainer.ru/api
# OAUTH__VK_CLIENT_ID=
# OAUTH__GOOGLE_CLIENT_ID=
# OAUTH__GOOGLE_CLIENT_SECRET=
# OAUTH__YANDEX_CLIENT_ID=
# OAUTH__YANDEX_CLIENT_SECRET=

# --- Execution limits (single server, ~50–100 testers) ---
EXECUTION_GLOBAL_MAX_QUEUE=200
EXECUTION_USER_MAX_PER_MINUTE=30
EXECUTION_USER_MAX_CONCURRENT=2
WORKER_SCALE=2

# --- Optional: first admin (run with SEED_ADMIN=1 ./deploy/scripts/init-prod.sh) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
SEED_ADMIN_NAME=Admin

# Swagger in production (default off)
ENABLE_OPENAPI_DOCS=false

# Автобэкап БД (сервис db_backup — поднимается вместе со стеком, раз в сутки)
# Файлы: backups/db/*.dump на хосте; старые удаляются автоматически
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=21
BACKUP_RETENTION_MAX_COUNT=30
