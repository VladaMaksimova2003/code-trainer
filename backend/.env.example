# Optional PYTHONPATH: packages live in backend/ root (api, domain, application, …).
# Run uvicorn from backend/:  uvicorn main:app --reload
# PYTHONPATH=

# CORS (comma-separated). Prod example: https://trainer.example.com
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080

DB__NAME=
DB__HOST=
DB__PORT=
DB__USER=
DB__PASSWORD=
DB__DIALECT=
DB__POOL_SIZE=
DB__MAX_OVERFLOW=
DB__ECHO=
# false = только данные из БД (редактор преподавателя); seed/sync из файлов не трогают задачи
CURRICULUM__CATALOG_SYNC_ENABLED=false
# 128 = 16×8 задач (MVP); 192 = полный v192-B (+4 задачи на сборник)
COURSE_SCOPE=128
AUTH__SECRET_KEY=
REDIS_HOST=
REDIS_PORT=
REDIS_DB=
SUBMISSION_QUEUE=
SUBMISSION_RESULT_PREFIX=
AUTH__ACCESS_TOKEN_TTL_MINUTES=240
AUTH__REFRESH_TOKEN_TTL_DAYS=30

# OAuth (social login). Leave client ids empty to disable a provider.
# Redirect URI in provider consoles: {OAUTH__REDIRECT_BASE}/auth/oauth/{vk|google|yandex}/callback
# OAUTH__FRONTEND_URL=http://localhost:5173
# OAUTH__REDIRECT_BASE=http://127.0.0.1:8001
# OAUTH__VK_CLIENT_ID=
# OAUTH__GOOGLE_CLIENT_ID=
# OAUTH__GOOGLE_CLIENT_SECRET=
# OAUTH__YANDEX_CLIENT_ID=
# OAUTH__YANDEX_CLIENT_SECRET=

# Email — один SMTP-сервер приложения отправляет код на ЛЮБОЙ email пользователя.
# Локально по умолчанию: Mailpit (docker compose up mailpit → http://localhost:8025).
# SMTP__HOST=
# SMTP__PORT=1025
# SMTP__USE_TLS=false
# SMTP__FROM_EMAIL=noreply@code-trainer.local
# Продакшен (пример): SMTP__HOST=smtp.example.com SMTP__PORT=587 SMTP__USER=... SMTP__PASSWORD=...
